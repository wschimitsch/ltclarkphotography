<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title or "LTClark Photography" }}</title>
    <link rel="icon" type="image/svg+xml" href="/assets/icons/favicon.svg">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300..700;1,300..700&family=Host+Grotesk:ital,wght@0,300..800;1,300..800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" integrity="sha384-LN+7fdVzj6u52u30Kp6M/trliBMCMKTyK833zpbD+pXdCLuTusPj697FH4R/5mcr" crossorigin="anonymous">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/assets/styles.css">
    {% if emailJS %}
    <script type="text/javascript" src="https://cdn.jsdelivr.net/npm/@emailjs/browser@4/dist/email.min.js"></script>
    <script src="/assets/email.js"></script>
    {% endif %}
</head>
<body class="{{ bodyClass or '' }}">
    <nav class="navbar {{ navbarClass or 'navbar-dark' }} fixed-top navbar-expand-lg justify-space-between">
        <a class="navbar-brand fw-bold" href="/">LTClark Photography</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarSupportedContent">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarSupportedContent">
            <ul class="navbar-nav ms-lg-auto align-items-start">
                <li class="nav-item{% if activeNav == 'home' %} active{% endif %}">
                    <a class="nav-link{% if activeNav == 'home' %} active{% endif %}" role="button" href="/">Home</a>
                </li>
                <li class="nav-item{% if activeNav == 'about' %} active{% endif %}">
                    <a class="nav-link{% if activeNav == 'about' %} active{% endif %}" role="button" href="/about.html">About</a>
                </li>
                <li class="nav-item{% if activeNav == 'galleries' %} active{% endif %}">
                    <a class="nav-link{% if activeNav == 'galleries' %} active{% endif %}" role="button" href="/galleries/gallery.html">Galleries</a>
                </li>
                <li class="nav-item{% if activeNav == 'contact' %} active{% endif %}">
                    <a class="nav-link{% if activeNav == 'contact' %} active{% endif %}" role="button" href="/contact.html">Contact</a>
                </li>
            </ul>
        </div>
    </nav>

    {{ content | safe }}

    <footer class="bg-dark text-light pt-4 pb-3 mt-5">
        <div class="container">
            <div class="row">
                <div class="col mb-3">
                    <h5>Quick Links</h5>
                    <ul class="list-unstyled d-flex flex-wrap gap-3 small mb-0">
                        <li><a href="/" class="text-light text-decoration-none">Home</a></li>
                        <li><a href="/about.html" class="text-light text-decoration-none">About</a></li>
                        <li><a href="/galleries/gallery.html" class="text-light text-decoration-none">Gallery</a></li>
                        <li><a href="/contact.html" class="text-light text-decoration-none">Contact</a></li>
                    </ul>
                </div>
                <div class="col mb-3">
                    <h5>Contact</h5>
                    <ul class="list-unstyled small">
                        <li><i class="bi bi-envelope me-2"></i> laurentclarkphotography@gmail.com</li>
                        <li><i class="bi bi-geo-alt me-2"></i> Morris County, NJ</li>
                    </ul>
                </div>
            </div>
            <hr class="border-secondary">
            <div class="text-center small">
                <p>&copy; <span id="year"></span> Lauren T. Clark Photography</p>
            </div>
        </div>
    </footer>

    <script>document.getElementById("year").textContent = new Date().getFullYear();</script>
    <script src="/assets/animation.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/js/bootstrap.min.js" integrity="sha384-7qAoOXltbVP82dhxHAUje59V5r2YsVfBafyUDxEdApLPmcdhBPg1DKg1ERo0BZlK" crossorigin="anonymous"></script>
</body>
</html>
